<?xml version = "1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <preference for="Shubo\BogPayment\Api\Data\SplitPaymentDataInterface"
                type="Shubo\BogPayment\Model\SplitPaymentData"/>

    <!-- BOG Payment Gateway Config -->
    <virtualType name="ShuboBogPaymentConfig" type="Magento\Payment\Gateway\Config\Config">
        <arguments>
            <argument name="methodCode" xsi:type="const">Shubo\BogPayment\Gateway\Config\Config::METHOD_CODE</argument>
        </arguments>
    </virtualType>

    <type name="Shubo\BogPayment\Gateway\Config\Config">
        <arguments>
            <argument name="methodCode" xsi:type="const">Shubo\BogPayment\Gateway\Config\Config::METHOD_CODE</argument>
            <!-- BUG-BOG-15: environment-aware API URL resolver -->
            <argument name="apiUrlResolver" xsi:type="object">Shubo\BogPayment\Gateway\Config\ApiUrlResolver\Proxy</argument>
        </arguments>
    </type>

    <!-- Dedicated log file for BOG payment -->
    <virtualType name="ShuboBogPaymentLogHandler" type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <argument name="fileName" xsi:type="string">/var/log/shubo_bog_payment.log</argument>
        </arguments>
    </virtualType>

    <virtualType name="ShuboBogPaymentLogger" type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="name" xsi:type="string">shubo_bog_payment</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">ShuboBogPaymentLogHandler</item>
            </argument>
        </arguments>
    </virtualType>

    <!-- Payment Method Facade -->
    <virtualType name="ShuboBogPaymentFacade" type="Magento\Payment\Model\Method\Adapter">
        <arguments>
            <argument name="code" xsi:type="const">Shubo\BogPayment\Gateway\Config\Config::METHOD_CODE</argument>
            <argument name="formBlockType" xsi:type="string">Magento\Payment\Block\Form</argument>
            <argument name="infoBlockType" xsi:type="string">Shubo\BogPayment\Block\Payment\Info</argument>
            <argument name="valueHandlerPool" xsi:type="object">ShuboBogValueHandlerPool</argument>
            <argument name="commandPool" xsi:type="object">ShuboBogCommandPool</argument>
            <argument name="validatorPool" xsi:type="object">ShuboBogValidatorPool</argument>
        </arguments>
    </virtualType>

    <!-- Value Handler Pool -->
    <virtualType name="ShuboBogValueHandlerPool" type="Magento\Payment\Gateway\Config\ValueHandlerPool">
        <arguments>
            <argument name="handlers" xsi:type="array">
                <item name="default" xsi:type="string">ShuboBogConfigValueHandler</item>
            </argument>
        </arguments>
    </virtualType>

    <virtualType name="ShuboBogConfigValueHandler" type="Magento\Payment\Gateway\Config\ConfigValueHandler">
        <arguments>
            <argument name="configInterface" xsi:type="object">ShuboBogPaymentConfig</argument>
        </arguments>
    </virtualType>

    <!-- Validator Pool -->
    <virtualType name="ShuboBogValidatorPool" type="Magento\Payment\Gateway\Validator\ValidatorPool">
        <arguments>
            <argument name="validators" xsi:type="array">
                <item name="country" xsi:type="string">ShuboBogCountryValidator</item>
            </argument>
        </arguments>
    </virtualType>

    <virtualType name="ShuboBogCountryValidator" type="Magento\Payment\Gateway\Validator\CountryValidator">
        <arguments>
            <argument name="config" xsi:type="object">ShuboBogPaymentConfig</argument>
        </arguments>
    </virtualType>

    <!-- Command Pool -->
    <virtualType name="ShuboBogCommandPool" type="Magento\Payment\Gateway\Command\CommandPool">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="initialize" xsi:type="string">ShuboBogInitializeCommand</item>
                <item name="refund" xsi:type="string">ShuboBogRefundCommand</item>
            </argument>
        </arguments>
    </virtualType>

    <!-- Initialize Command (Create BOG Order) -->
    <virtualType name="ShuboBogInitializeCommand" type="Magento\Payment\Gateway\Command\GatewayCommand">
        <arguments>
            <argument name="requestBuilder" xsi:type="object">ShuboBogInitializeRequestBuilder</argument>
            <argument name="transferFactory" xsi:type="object">Shubo\BogPayment\Gateway\Http\TransferFactory</argument>
            <argument name="client" xsi:type="object">Shubo\BogPayment\Gateway\Http\Client\CreatePaymentClient</argument>
            <argument name="handler" xsi:type="object">Shubo\BogPayment\Gateway\Response\InitializeHandler</argument>
            <argument name="validator" xsi:type="object">Shubo\BogPayment\Gateway\Validator\ResponseValidator</argument>
        </arguments>
    </virtualType>

    <virtualType name="ShuboBogInitializeRequestBuilder" type="Magento\Payment\Gateway\Request\BuilderComposite">
        <arguments>
            <argument name="builders" xsi:type="array">
                <item name="initialize" xsi:type="string">Shubo\BogPayment\Gateway\Request\InitializeRequestBuilder</item>
                <item name="split" xsi:type="string">Shubo\BogPayment\Gateway\Request\SplitDataBuilder</item>
            </argument>
        </arguments>
    </virtualType>

    <!-- Refund Command.
         Session 8 Priority 1.1: NO validator. The
         `Magento\Payment\Gateway\Command\GatewayCommand::execute` pipeline
         calls the validator AFTER the client and BEFORE the handler — a
         non-2xx response would short-circuit through `processErrors()` as a
         `CommandException` and the handler would never reach the
         `UserFacingErrorMapper`. The handler is the sole gatekeeper for
         refund failures so it can route raw BOG envelopes through the
         friendly-error mapper. Regression-guarded by
         `Test/Unit/Gateway/Command/RefundCommandPipelineTest`. Mirrors TBC
         reviewer-signoff M-1. -->
    <virtualType name="ShuboBogRefundCommand" type="Magento\Payment\Gateway\Command\GatewayCommand">
        <arguments>
            <argument name="requestBuilder" xsi:type="object">Shubo\BogPayment\Gateway\Request\RefundRequestBuilder</argument>
            <argument name="transferFactory" xsi:type="object">Shubo\BogPayment\Gateway\Http\TransferFactory</argument>
            <argument name="client" xsi:type="object">Shubo\BogPayment\Gateway\Http\Client\RefundClient</argument>
            <argument name="handler" xsi:type="object">Shubo\BogPayment\Gateway\Response\RefundHandler</argument>
        </arguments>
    </virtualType>

    <!-- Transfer Factory Config -->
    <type name="Shubo\BogPayment\Gateway\Http\TransferFactory">
        <arguments>
            <argument name="config" xsi:type="object">Shubo\BogPayment\Gateway\Config\Config</argument>
        </arguments>
    </type>

    <!-- HTTP Clients -->
    <type name="Shubo\BogPayment\Gateway\Http\Client\CreatePaymentClient">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboBogPaymentLogger</argument>
        </arguments>
    </type>

    <type name="Shubo\BogPayment\Gateway\Http\Client\RefundClient">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboBogPaymentLogger</argument>
        </arguments>
    </type>

    <!-- Session 8 Priority 1.1 — RefundHandler routes BOG-side refund failures
         through UserFacingErrorMapper. Dedicated logger so the raw triple
         lands in the BOG payment log alongside the rest of the refund trace. -->
    <type name="Shubo\BogPayment\Gateway\Response\RefundHandler">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboBogPaymentLogger</argument>
        </arguments>
    </type>

    <type name="Shubo\BogPayment\Gateway\Http\Client\StatusClient">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboBogPaymentLogger</argument>
        </arguments>
    </type>

    <type name="Shubo\BogPayment\Gateway\Http\Client\CaptureClient">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboBogPaymentLogger</argument>
        </arguments>
    </type>

    <type name="Shubo\BogPayment\Gateway\Validator\CallbackValidator">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboBogPaymentLogger</argument>
            <argument name="config" xsi:type="object">Shubo\BogPayment\Gateway\Config\Config</argument>
        </arguments>
    </type>

    <type name="Shubo\BogPayment\Controller\Payment\Callback">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboBogPaymentLogger</argument>
        </arguments>
    </type>

    <!-- BUG-BOG-9 / BUG-BOG-OAUTH-CACHE-TYPE: per-storeId OAuth token cache.
         Uses Magento\Framework\App\Cache\Type\Config (the `config` cache
         type, frontend `cache.static` under the hood) — persistent across
         PHP-FPM workers, cleared via `bin/magento cache:clean config`
         whenever BOG credentials are rotated.

         NOTE: the constructor argument is typed `Magento\Framework\Cache\FrontendInterface`
         (not `Magento\Framework\App\CacheInterface`). `Type\Config extends TagScope`,
         which implements FrontendInterface. An earlier commit typed the arg
         as `App\CacheInterface` and crashed every `pending_order_reconciler`
         tick for ~8 h until Session 2 (2026-04-23) caught it via system.log
         grep (486 `Type Error` lines / 24h). -->
    <type name="Shubo\BogPayment\Model\OAuthTokenProvider">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboBogPaymentLogger</argument>
            <argument name="cache" xsi:type="object">Magento\Framework\App\Cache\Type\Config</argument>
        </arguments>
    </type>

    <!-- BUG-BOG-6: shared advisory-lock service for capture-path serialization -->
    <type name="Shubo\BogPayment\Service\PaymentLock">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboBogPaymentLogger</argument>
        </arguments>
    </type>

    <!-- Frontend Payment Controllers -->
    <type name="Shubo\BogPayment\Controller\Payment\Initiate">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboBogPaymentLogger</argument>
        </arguments>
    </type>

    <type name="Shubo\BogPayment\Controller\Payment\ReturnAction">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboBogPaymentLogger</argument>
        </arguments>
    </type>

    <type name="Shubo\BogPayment\Controller\Payment\Confirm">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboBogPaymentLogger</argument>
        </arguments>
    </type>

    <type name="Shubo\BogPayment\Controller\Payment\AbortRedirect">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboBogPaymentLogger</argument>
        </arguments>
    </type>

    <!-- Cron -->
    <!-- BUG-BOG-12: creditmemoFactory/creditmemoManagement wired for
         BOG-driven refund reconciliation. -->
    <type name="Shubo\BogPayment\Cron\PendingOrderReconciler">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboBogPaymentLogger</argument>
            <argument name="creditmemoFactory" xsi:type="object">Magento\Sales\Model\Order\CreditmemoFactory</argument>
            <argument name="creditmemoManagement" xsi:type="object">Magento\Sales\Api\CreditmemoManagementInterface</argument>
        </arguments>
    </type>

    <!-- Admin Controllers -->
    <!-- Session 8 P2.2 — UserFacingErrorMapper retrofit so admin no longer
         sees raw BOG API exception text in toast messages. -->
    <type name="Shubo\BogPayment\Controller\Adminhtml\Order\CheckStatus">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboBogPaymentLogger</argument>
        </arguments>
    </type>

    <type name="Shubo\BogPayment\Controller\Adminhtml\Order\Capture">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboBogPaymentLogger</argument>
        </arguments>
    </type>

    <type name="Shubo\BogPayment\Controller\Adminhtml\Order\VoidPayment">
        <arguments>
            <argument name="logger" xsi:type="object">ShuboBogPaymentLogger</argument>
        </arguments>
    </type>

    <!-- Prod cutover CLI (GO_LIVE_CHECKLIST §3.2). Shares the
         payment-cutover.log virtualType definition with Shubo_TbcPayment
         via distinct names so di.xml merging does not collide. -->
    <virtualType name="ShuboBogPaymentCutoverLogHandler" type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <argument name="fileName" xsi:type="string">/var/log/payment-cutover.log</argument>
        </arguments>
    </virtualType>

    <virtualType name="ShuboBogPaymentCutoverLogger" type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="name" xsi:type="string">shubo_payment_cutover</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">ShuboBogPaymentCutoverLogHandler</item>
            </argument>
        </arguments>
    </virtualType>

    <type name="Shubo\BogPayment\Console\Command\SwitchToProdCommand">
        <arguments>
            <argument name="cutoverLogger" xsi:type="object">ShuboBogPaymentCutoverLogger</argument>
        </arguments>
    </type>

    <!-- Bind on the INTERFACE, never the concrete CommandList (BUG-SETUP-1). -->
    <type name="Magento\Framework\Console\CommandListInterface">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="shubo_payment_switch_to_prod_bog"
                      xsi:type="object">Shubo\BogPayment\Console\Command\SwitchToProdCommand</item>
            </argument>
        </arguments>
    </type>
</config>
